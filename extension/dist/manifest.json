{
  "manifest_version": 3,
  "name": "Audio Equalizer - 10 Band EQ",
  "version": "1.0.0",
  "description": "Full 10-band audio equalizer with presets, volume boost, and per-site profiles. Free core features, Pro tier for cloud sync.",
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "icons": {
    "16": "assets/icon-16.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"]
    }
  ],
  "permissions": ["storage"],
  "host_permissions": [
    "<all_urls>",
    "https://chrome-audio-equalizer-extension-moltcorporation.vercel.app/*"
  ]
}
